<resources>
    <string name="app_name">Numbrix</string>
    <style name="keypadBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">62dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:backgroundTint">@color/btn_number</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">20sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="keypadHex">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">62dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:backgroundTint">@color/btn_hex</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">20sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="keypadS">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">62dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:backgroundTint">@color/btn_special</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">20sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="keypadEqual" parent="keypadS">
        <item name="android:backgroundTint">@color/btn_equal</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>
    <string-array name="operations">
        <item>Binary</item>
        <item>Octal</item>
        <item>Decimal</item>
        <item>Hexadecimal</item>
    </string-array>
    <string name="binary_prefix">Binary: %1$s</string>
    <string name="octal_prefix">Octal: %1$s</string>
    <string name="enter_value">Enter Value</string>
    <string name="invalid_input">Not a valid %1$s number</string>
</resources>